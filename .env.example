# SOWTEE Backend Environment Configuration
# Copy this to .env and fill in your values

# Application
DEBUG=false
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# Google Gemini API (legacy - used for vision)
GEMINI_API_KEY=AIzaSyCzYT0rIApzTGqdX3hhUgb2KQjN83_bP14
GEMINI_VISION_MODEL=gemini-2.0-flash
GEMINI_TEXT_MODEL=gemini-2.0-flash-lite
GEMINI_MAX_TOKENS=1024
GEMINI_TEMPERATURE=0.7

# Groq API (primary for text and vision generation)
# Best-in-class models for each task
GROQ_API_KEY=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

# Vision model: Llama 4 Scout - Multimodal, 17B params, 16 experts
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Reasoning model: Qwen3-32B - Best for complex reasoning/expansion  
GROQ_REASONING_MODEL=qwen/qwen3-32b

# General model: Llama 3.3 70B - High quality, versatile
GROQ_GENERAL_MODEL=llama-3.3-70b-versatile

# Fallback: Llama 3.1 8B - Ultra-fast fallback
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant


# Lingo.dev Translation API (for EN→AR translation)
LINGODOTDEV_API_KEY=api_bmw7ee56xaylz944nb328axa

UPLIFTAI_API_KEY=sk_api_8be18dd38efab399cb5c117acd7ea33c66f4f04cf0e95e81da551597a2046fc8

# ElevenLabs TTS API
ELEVENLABS_API_KEY=sk_41dd3af9c7d95dfb9d060376ee55b8f4d4a0f3df65729f1b
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# Vector Database (ChromaDB)
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=sowtee_memory

# Agentic Orchestrator Settings
MAX_REASONING_CYCLES=3
PREDICTION_CONFIDENCE_THRESHOLD=0.6
TOP_K_PHRASES=3
MEMORY_RETRIEVAL_LIMIT=10

# User Session
SESSION_TIMEOUT_MINUTES=60
MAX_HISTORY_ITEMS=100
