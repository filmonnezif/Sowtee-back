# SOWTEE Backend Environment Configuration
# Copy this to .env and fill in your values

# Application
DEBUG=false
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# Google Gemini API (required for vision and intent prediction)
GEMINI_API_KEY=your-api-key-here
GEMINI_VISION_MODEL=gemini-2.0-flash
GEMINI_TEXT_MODEL=gemini-2.0-flash-lite
GEMINI_MAX_TOKENS=1024
GEMINI_TEMPERATURE=0.7

# Groq API (primary for text generation and TTS)
GROQ_API_KEY=your-groq-api-key-here

# Lingo.dev Translation API (for EN→AR/UR translation)
LINGODOTDEV_API_KEY=your-lingodotdev-api-key-here

# Uplift AI Urdu TTS API
UPLIFTAI_API_KEY=your-upliftai-api-key-here

# ElevenLabs TTS API
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# Vector Database (ChromaDB)
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=sowtee_memory

# Agentic Orchestrator Settings
MAX_REASONING_CYCLES=3
PREDICTION_CONFIDENCE_THRESHOLD=0.6
TOP_K_PHRASES=3
MEMORY_RETRIEVAL_LIMIT=10

# User Session
SESSION_TIMEOUT_MINUTES=60
MAX_HISTORY_ITEMS=100
